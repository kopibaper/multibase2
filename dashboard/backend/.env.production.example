# ============================================================
# Multibase Backend — Production Configuration Example
# ============================================================
# Diese Datei wird von deployment/install.sh automatisch
# als .env generiert. Hier stehen alle Variablen mit den
# Platzhaltern die das Install-Script befüllt.
#
# NICHT direkt verwenden — stattdessen:
#   sudo bash deployment/install.sh
# ============================================================

# Server
PORT=3001
NODE_ENV=production

# ============================================================
# DEPLOYMENT_MODE — lokal vs. Cloud/VPS
#   local  → kein nginx, Studio/Kong direkt über localhost:<port>
#   cloud  → nginx-Configs mit Domain + SSL werden generiert
# ============================================================
DEPLOYMENT_MODE=cloud

# Database (SQLite)
DATABASE_URL="file:./data/multibase.db"

# Redis (mit Passwort, generiert vom Installer)
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Paths (absolut, gesetzt vom Installer auf den INSTALL_DIR)
PROJECTS_PATH=/opt/multibase/projects
PYTHON_PATH=/opt/multibase/venv/bin/python3
BACKUP_PATH=/opt/multibase/backups
SHARED_DIR=/opt/multibase/shared

# ============================================================
# Domains — vom Installer abgefragt
# ============================================================
BACKEND_DOMAIN=backend.example.com
ROOT_DOMAIN=example.com
FRONTEND_DOMAIN=app.example.com

# URLs die aus den Domains abgeleitet werden
DASHBOARD_URL=https://app.example.com
BACKEND_URL=https://backend.example.com
APP_URL=https://app.example.com

# Cookie Domain für Cross-Subdomain-Authentifizierung
COOKIE_DOMAIN=.example.com

# CORS — Frontend-URL
CORS_ORIGIN=https://app.example.com

# ============================================================
# SSL / Certbot
# ============================================================
SSL_EMAIL=admin@example.com
CERTBOT_EMAIL=admin@example.com
# SSL_TYPE: 'per-tenant' (ein Cert pro Instanz) oder 'wildcard'
SSL_TYPE=per-tenant

# ============================================================
# Security — vom Installer zufällig generiert
# ============================================================
SESSION_SECRET=<RANDOM_64_CHAR_STRING>

# ============================================================
# Initial Admin-Account (nur beim ersten Start genutzt)
# ============================================================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=<SECURE_PASSWORD>

# ============================================================
# Zoraxy Reverse Proxy (optional — auto-registers tenant subdomains)
# ============================================================
# ZORAXY_ADMIN_URL=http://zoraxy:8899
# ZORAXY_USERNAME=admin
# ZORAXY_PASSWORD=<ZORAXY_PASSWORD>
# ZORAXY_UPSTREAM_HOST=multibase-nginx-gateway

# ============================================================
# Logging & Monitoring
# ============================================================
LOG_LEVEL=info
METRICS_INTERVAL=15000
HEALTH_CHECK_INTERVAL=10000
ALERT_CHECK_INTERVAL=60000
