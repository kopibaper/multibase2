// Multibase Dashboard Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Organisation {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  members     OrgMember[]
  instances   Instance[]

  @@index([slug])
}

model OrgMember {
  id       Int          @id @default(autoincrement())
  orgId    String
  userId   String
  role     String       @default("member") // 'owner' | 'admin' | 'member' | 'viewer'
  joinedAt DateTime     @default(now())
  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Instance {
  id          String      @id
  name        String      @unique
  basePort    Int
  status      String      // 'running', 'stopped', 'degraded', 'healthy'
  orgId       String?     // Optional: assigned to an organisation
  environment String?     // 'production' | 'staging' | 'dev' | 'preview' | null
  org         Organisation? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  metrics     Metric[]
  alerts      Alert[]
  alertRules  AlertRule[]
  uptime      UptimeRecord[]
  readReplicas        ReadReplica[]
  logDrains           LogDrain[]
  installedExtensions InstalledExtension[]

  @@index([name])
  @@index([status])
  @@index([orgId])
}

model UptimeRecord {
  id          Int      @id @default(autoincrement())
  instanceId  String
  status      String   // 'up', 'down', 'degraded'
  responseTime Int?    // in ms
  timestamp   DateTime @default(now())
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, timestamp])
}

model Metric {
  id          Int      @id @default(autoincrement())
  instanceId  String
  service     String   // 'kong', 'studio', 'db', 'auth', etc.
  cpu         Float    // CPU percentage
  memory      Float    // Memory in MB
  networkRx   Float    // Network received in bytes
  networkTx   Float    // Network transmitted in bytes
  diskRead    Float    // Disk read in bytes
  diskWrite   Float    // Disk write in bytes
  timestamp   DateTime @default(now())
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, timestamp])
  @@index([service])
}

model Alert {
  id            Int       @id @default(autoincrement())
  instanceId    String
  name          String    // Alert name (from rule)
  rule          String    // 'service_down', 'high_cpu', 'high_memory', etc.
  status        String    // 'active', 'acknowledged', 'resolved'
  message       String?   // Alert message
  condition     String?   // Restore column to prevent data loss
  duration      Int?      // Restore column to prevent data loss
  enabled       Boolean?  // Restore column to prevent data loss
  notificationChannels String? // Restore column to prevent data loss
  threshold     Float?    // Restore column to prevent data loss
  triggeredAt   DateTime?
  acknowledgedAt DateTime?
  resolvedAt    DateTime?
  metadata      String?   // JSON string with additional data
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  instance      Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([status])
  @@index([rule])
}

model AlertRule {
  id                   Int       @id @default(autoincrement())
  instanceId           String
  name                 String    // Rule name
  rule                 String    // 'service_down', 'high_cpu', 'high_memory', 'high_disk', 'slow_response'
  threshold            Float?    // Threshold value (e.g., 80 for 80%)
  duration             Int?      // Duration in seconds before triggering
  enabled              Boolean   @default(true)
  notificationChannels String?   // JSON array of channels ['browser', 'webhook']
  webhookUrl           String?   // Webhook URL for notifications
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  instance             Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([enabled])
}

model SystemMetric {
  id          Int      @id @default(autoincrement())
  totalCpu    Float
  totalMemory Float
  totalDisk   Float
  instanceCount Int
  runningCount  Int
  timestamp   DateTime @default(now())

  @@index([timestamp])
}

model User {
  id               String              @id @default(uuid())
  email            String              @unique
  username         String              @unique
  passwordHash     String
  role             String              @default("user") // 'admin', 'user', 'viewer'
  isActive         Boolean             @default(true)
  avatar           String?             // Avatar URL/Path
  twoFactorEnabled Boolean             @default(false)
  twoFactorSecret  String?             // TOTP Secret for 2FA
  
  // AI Assistant
  aiProvider          String?          // 'openai', 'gemini', 'anthropic', 'openrouter'
  aiApiKeyEncrypted   String?          // AES-256-GCM encrypted API key
  aiModel             String?          // Selected model ID (e.g. 'gpt-4o-mini')
  
  // Password Reset & Email Verification
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  verificationToken    String?
  isEmailVerified      Boolean         @default(false)
  
  lastLogin        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sessions         Session[]
  backups          Backup[]
  auditLogs        AuditLog[]
  apiKeys          ApiKey[]
  templates        InstanceTemplate[]
  aiChatSessions   AiChatSession[]
  orgMemberships   OrgMember[]

  @@index([email])
  @@index([role])
}

model AiChatSession {
  id        String          @id @default(uuid())
  userId    String
  title     String          @default("New Chat")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiChatMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model AiChatMessage {
  id          Int            @id @default(autoincrement())
  sessionId   String
  role        String         // 'user', 'assistant', 'tool'
  content     String
  toolCalls   String?        // JSON array of tool calls
  toolResults String?        // JSON array of tool results
  createdAt   DateTime       @default(now())
  session     AiChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Backup {
  id          String   @id @default(uuid())
  name        String
  type        String   // 'full', 'instance', 'database'
  instanceId  String?  // null for full backups
  size        Int      // Size in bytes
  path        String   // File path
  createdBy   String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [createdBy], references: [id])

  @@index([type])
  @@index([instanceId])
  @@index([createdAt])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      String?  // null for unauthenticated actions (e.g., failed login)
  action      String   // 'create_instance', 'delete_backup', 'login', 'login_failed', etc.
  resource    String   // 'instance/test1', 'backup/123', 'user/5', 'auth/login'
  details     String?  // JSON with additional info (request body, query params)
  ipAddress   String?
  userAgent   String?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([success])
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  userId      String
  name        String    // Descriptive name for the key
  key         String    @unique // Hashed API Key
  keyPrefix   String    // First 8 characters for identification (e.g., "mb_abc123")
  scopes      String    // JSON array: ["instances:read", "backups:create", "*"]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
  @@index([keyPrefix])
}

model InstanceTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  config      String   // JSON: deploymentType, basePort, corsOrigins, services
  isPublic    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  creator     User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([isPublic])
  @@index([createdBy])
}

model BackupSchedule {
  id           Int       @id @default(autoincrement())
  instanceId   String    // Instance to backup
  cronSchedule String    // "0 2 * * *" = daily 02:00
  type         String    // "full", "database", "instance"
  retention    Int       @default(7)  // Keep last N backups
  enabled      Boolean   @default(true)
  lastRun      DateTime?
  nextRun      DateTime?
  lastStatus   String?   // "success", "failed"
  lastError    String?   // Error message if failed
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([instanceId])
  @@index([enabled])
  @@index([nextRun])
}

model Webhook {
  id          Int       @id @default(autoincrement())
  name        String
  instanceId  String?   // null = all instances
  source      String    // "github", "gitlab", "custom"
  secret      String    // Webhook secret for verification
  events      String    // JSON: ["push", "release", "tag"]
  enabled     Boolean   @default(true)
  lastTriggered DateTime?
  triggerCount Int      @default(0)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([instanceId])
  @@index([source])
  @@index([enabled])
}

model Deployment {
  id          Int       @id @default(autoincrement())
  instanceId  String
  version     String?   // Git tag, commit hash, or version number
  status      String    // "pending", "running", "success", "failed", "rolled_back"
  source      String    // "webhook", "manual", "scheduled"
  triggeredBy String?   // User ID or "webhook"
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  duration    Int?      // Duration in seconds
  logs        String?   // Deployment logs
  error       String?   // Error message if failed
  rollbackOf  Int?      // ID of deployment this rolled back
  createdAt   DateTime  @default(now())

  @@index([startedAt])
}

model MigrationTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  sql         String
  category    String   @default("custom") // 'system', 'custom'
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
}

model GlobalSettings {
  id                Int      @id @default(1)
  smtp_host         String?
  smtp_port         Int?     @default(587)
  smtp_user         String?
  smtp_pass         String?
  smtp_sender_name  String?
  smtp_admin_email  String?
  app_url           String?  // Public URL for email links
  feedbackEnabled   Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model CustomDomain {
  id           Int      @id @default(autoincrement())
  instanceName String
  domain       String
  status       String   @default("pending_dns") // 'pending_dns' | 'dns_verified' | 'ssl_active' | 'error'
  errorMsg     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([instanceName, domain])
  @@index([instanceName])
}

model ReadReplica {
  id          String   @id @default(uuid())
  instanceId  String
  name        String
  url         String
  status      String   @default("provisioning") // 'provisioning' | 'active' | 'error' | 'syncing'
  lagBytes    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

model LogDrain {
  id           String    @id @default(uuid())
  instanceId   String
  name         String
  url          String
  services     String    @default("[]") // JSON array of service names ['db', 'auth', 'storage', 'realtime']
  format       String    @default("json") // 'json' | 'ndjson' | 'logfmt'
  enabled      Boolean   @default(true)
  lastStatus   String?   // 'ok' | 'error'
  lastDelivery DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  instance     Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

// ─── Extension Marketplace ────────────────────────────────────────────────────

model Extension {
  id               String   @id                   // e.g. "ecommerce-starter"
  name             String
  description      String
  longDescription  String?
  version          String
  author           String
  authorUrl        String?
  category         String                          // 'database'|'auth'|'functions'|'monitoring'|'ai'|'storage'
  tags             String                          // comma-separated: "ecommerce,schema,starter"
  iconUrl          String?
  screenshotUrls   String?                         // comma-separated URLs
  verified         Boolean  @default(false)
  featured         Boolean  @default(false)
  installCount     Int      @default(0)
  rating           Float?
  minVersion       String   @default("1.0.0")
  requiresExtensions String?                       // comma-separated postgres extensions
  installType      String                          // 'sql'|'function'|'config'|'composite'
  manifestUrl      String
  configSchema     String?                         // JSON: configSchema field definitions for install wizard
  latestVersion    String?                         // latest available version for auto-update checker
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  installations    InstalledExtension[]
  reviews          ExtensionReview[]

  @@index([category])
  @@index([featured])
}

model InstalledExtension {
  id          String   @id @default(uuid())
  instanceId  String
  extensionId String
  version     String
  status      String   @default("active")          // 'active'|'error'|'updating'|'disabled'
  config      String?                              // JSON: user-defined config values
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instance    Instance  @relation(fields: [instanceId],  references: [id], onDelete: Cascade)
  extension   Extension @relation(fields: [extensionId], references: [id])

  @@unique([instanceId, extensionId])
  @@index([instanceId])
}

model ExtensionReview {
  id          String   @id @default(uuid())
  extensionId String
  rating      Int                                  // 1–5
  comment     String?
  authorName  String?                              // display name (optional)
  createdAt   DateTime @default(now())

  extension   Extension @relation(fields: [extensionId], references: [id], onDelete: Cascade)

  @@index([extensionId])
}

model Feedback {
  id          Int      @id @default(autoincrement())
  type        String   // 'feature' | 'bug'
  title       String
  description String
  urgency     String   // 'low' | 'medium' | 'high' | 'critical'
  authorName  String?
  authorEmail String?  // never exposed in GET responses
  status      String   @default("open") // 'open' | 'in_progress' | 'resolved' | 'closed'
  ipAddress   String?  // stored for moderation, never exposed

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
