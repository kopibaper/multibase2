# Server Configuration
PORT=3001
NODE_ENV=development

# ============================================================
# DEPLOYMENT_MODE — der zentrale Schalter für lokal vs. VPS
#   local  → kein nginx, Studio/Kong direkt über localhost:<port>
#   cloud  → nginx-Configs mit Domain + SSL werden generiert
# → Nach "git clone" einfach diese Datei kopieren: cp .env.example .env
#   DEPLOYMENT_MODE=local ist der sichere Default für Entwicklung.
# ============================================================
DEPLOYMENT_MODE=local

# Database
DATABASE_URL="file:./data/multibase.db"

# Redis
REDIS_URL=redis://localhost:6379

# Docker
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# For Windows Docker Desktop use named pipe
DOCKER_HOST=npipe:////./pipe/docker_engine
# DOCKER_SOCKET_PATH=

# Multibase Projects Path
PROJECTS_PATH=../../projects

# Python executable path (Windows)
PYTHON_PATH=C:\Program Files\Python39\python.exe

# CORS
CORS_ORIGIN=http://85.114.138.116:5173, http://localhost:5173

# Logging
LOG_LEVEL=info

# Metrics Collection
METRICS_INTERVAL=15000
HEALTH_CHECK_INTERVAL=10000

# Alert Configuration
ALERT_CHECK_INTERVAL=60000

# Session Secret (change this in production!)
SESSION_SECRET=your-secret-key-change-in-production-min-32-chars

# App URL (used for email links)
APP_URL=http://localhost:5173

# Dashboard & Instance Access URLs
DASHBOARD_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Nur für DEPLOYMENT_MODE=cloud — auf dem VPS belegen:
# BACKEND_DOMAIN=backend.tyto-design.de
# ROOT_DOMAIN=tyto-design.de
# FRONTEND_DOMAIN=app.tyto-design.de

# Cookie Domain
# Set this to enable cross-subdomain authentication for instances
# For production with a domain like multibase.example.com and instances like instance1.example.com
# use: COOKIE_DOMAIN=.example.com (note the leading dot)
# Leave unset for development/localhost
# COOKIE_DOMAIN=.tyto-design.de

# Zoraxy Reverse Proxy (optional — auto-registers tenant subdomains)
# ZORAXY_ADMIN_URL=http://zoraxy:8899
# ZORAXY_USERNAME=admin
# ZORAXY_PASSWORD=your-zoraxy-password
# ZORAXY_UPSTREAM_HOST=multibase-nginx-gateway

# SMTP Configuration (optional - can also be set in Dashboard Settings)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Multibase" <noreply@example.com>